# godeploy-platform environment template
# Copy to .env and adjust as needed.

# HTTP server (godeployd)
GODEPLOY_ADDR=:8081

# SQLite database path (godeployd + godeploy-tui)
GODEPLOY_DB=godeploy.db

# Docker network name used for managed containers
GODEPLOY_NETWORK=godeploy

# Default docker image prefix for builds
GODEPLOY_IMAGE_PREFIX=godeploy

# Health check path used during rollout (must start with /)
GODEPLOY_HEALTH_PATH=/

# Webhook shared secret
# - GitHub: used for HMAC SHA256 verification (X-Hub-Signature-256)
# - GitLab: used for X-Gitlab-Token validation
GODEPLOY_WEBHOOK_SECRET=change-me

# POST /webhook rate limit per client IP (token bucket)
GODEPLOY_WEBHOOK_RPS=5
GODEPLOY_WEBHOOK_BURST=30

# Extra browser Origins allowed for GET /api/ws/logs (comma-separated).
# Same-host requests are always allowed; empty = no extra cross-origins.
# Example: https://app.example.com,http://localhost:5173
GODEPLOY_WS_ALLOWED_ORIGINS=

# WebSocket URL base for godeploy-logtail (path + query ?container= is appended)
# Example: ws://127.0.0.1:8081/api/ws/logs
GODEPLOY_LOG_WS_URL=ws://127.0.0.1:8081/api/ws/logs
